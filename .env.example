# Copy to .env.local for local dev. DO NOT COMMIT .env.local and DO NOT BAKE
# KEYS INTO A PUBLIC DEPLOY — Vite embeds VITE_* vars into the JS bundle, which
# is readable by anyone.

# Free tier: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Optional endpoint override. Leave blank for the default.
VITE_GEMINI_BASE_URL=
